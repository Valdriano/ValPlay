<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ValPlay.Pages.SplashPage"
             BackgroundColor="#0D1117"
             Shell.NavBarIsVisible="False">

    <Grid>
        <Ellipse x:Name="GlowRing"
                 WidthRequest="260"
                 HeightRequest="260"
                 HorizontalOptions="Center"
                 VerticalOptions="Center"
                 Stroke="#3300B4D8"
                 StrokeThickness="2"
                 Fill="#1100B4D8"
                 Opacity="0" />

        <Image x:Name="LogoImage"
               Source="valplay_logo"
               WidthRequest="180"
               HeightRequest="180"
               Aspect="AspectFit"
               HorizontalOptions="Center"
               VerticalOptions="Center"
               Opacity="0"
               Scale="0.6" />

        <Label x:Name="AppNameLabel"
               Text="ValPlay"
               FontSize="32"
               FontAttributes="Bold"
               TextColor="#F0F6FC"
               HorizontalOptions="Center"
               VerticalOptions="Center"
               Margin="0,140,0,0"
               Opacity="0" />
    </Grid>
</ContentPage>
