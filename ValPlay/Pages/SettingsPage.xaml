<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ValPlay.ViewModels"
             xmlns:controls="clr-namespace:ValPlay.Controls"
             x:Class="ValPlay.Pages.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             Title="{Binding PageTitle}"
             BackgroundColor="{StaticResource AppBackground}">

    <controls:VwSafeAreaLayout>
        <ScrollView>
            <VerticalStackLayout Padding="16" Spacing="16">

                <Label Text="{Binding LanguageTitle}"
                       Style="{StaticResource VwTitle}" />

                <Picker ItemsSource="{Binding Languages}"
                        SelectedItem="{Binding SelectedLanguage}"
                        Style="{StaticResource VwPicker}" />

                <BoxView HeightRequest="1" Color="{StaticResource SurfaceLight}" />

                <Label Text="{Binding PlaybackTitle}"
                       Style="{StaticResource VwTitle}" />

                <Grid ColumnDefinitions="*,Auto" Padding="0,8">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{Binding ShuffleTitle}"
                               FontSize="18"
                               TextColor="{StaticResource TextPrimary}" />
                        <Label Text="{Binding ShuffleHint}"
                               Style="{StaticResource VwCaption}" />
                    </VerticalStackLayout>
                    <Switch Grid.Column="1"
                            IsToggled="{Binding ShuffleEnabled}"
                            OnColor="{StaticResource Accent}" />
                </Grid>

                <VerticalStackLayout Spacing="8">
                    <Label Text="{Binding RepeatTitle}"
                           FontSize="18"
                           TextColor="{StaticResource TextPrimary}" />
                    <Picker ItemsSource="{Binding RepeatModeOptions}"
                            SelectedItem="{Binding SelectedRepeatMode}"
                            ItemDisplayBinding="{Binding Label}"
                            Style="{StaticResource VwPicker}" />
                </VerticalStackLayout>

                <Grid ColumnDefinitions="*,Auto" Padding="0,8">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{Binding ResumeTitle}"
                               FontSize="18"
                               TextColor="{StaticResource TextPrimary}" />
                        <Label Text="{Binding ResumeHint}"
                               Style="{StaticResource VwCaption}" />
                    </VerticalStackLayout>
                    <Switch Grid.Column="1"
                            IsToggled="{Binding ResumePlaybackOnStart}"
                            OnColor="{StaticResource Accent}" />
                </Grid>

                <VerticalStackLayout Spacing="8">
                    <Label Text="{Binding VisualizationTitle}"
                           FontSize="18"
                           TextColor="{StaticResource TextPrimary}" />
                    <Label Text="{Binding VisualizationHint}"
                           Style="{StaticResource VwCaption}" />
                    <Picker ItemsSource="{Binding VisualizationModeOptions}"
                            SelectedItem="{Binding SelectedVisualizationMode}"
                            ItemDisplayBinding="{Binding Label}"
                            Style="{StaticResource VwPicker}" />
                </VerticalStackLayout>

                <BoxView HeightRequest="1" Color="{StaticResource SurfaceLight}" />

                <Button Text="{Binding ClearSessionLabel}"
                        Command="{Binding ClearSavedSessionCommand}"
                        Style="{StaticResource VwControlButton}" />

            <Label Text="{Binding AppVersion, StringFormat='ValPlay v{0}'}"
                   Style="{StaticResource VwCaption}"
                   HorizontalOptions="Center"
                   Margin="0,16,0,0" />
            </VerticalStackLayout>
        </ScrollView>
    </controls:VwSafeAreaLayout>
</ContentPage>
