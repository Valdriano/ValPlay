<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ValPlay.ViewModels"
             xmlns:controls="clr-namespace:ValPlay.Controls"
             x:Class="ValPlay.Pages.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             Title="Configurações"
             BackgroundColor="{StaticResource AppBackground}">

    <controls:VwSafeAreaLayout>
        <ScrollView>
            <VerticalStackLayout Padding="16" Spacing="16">

                <Label Text="Reprodução"
                       Style="{StaticResource VwTitle}" />

                <Grid ColumnDefinitions="*,Auto" Padding="0,8">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Modo aleatório"
                               FontSize="18"
                               TextColor="{StaticResource TextPrimary}" />
                        <Label Text="Mantém ativo mesmo após desligar o carro"
                               Style="{StaticResource VwCaption}" />
                    </VerticalStackLayout>
                    <Switch Grid.Column="1"
                            IsToggled="{Binding ShuffleEnabled}"
                            OnColor="{StaticResource Accent}" />
                </Grid>

                <VerticalStackLayout Spacing="8">
                    <Label Text="Repetir"
                           FontSize="18"
                           TextColor="{StaticResource TextPrimary}" />
                    <Picker ItemsSource="{Binding RepeatModes}"
                            SelectedItem="{Binding RepeatMode}"
                            Style="{StaticResource VwPicker}" />
                </VerticalStackLayout>

                <Grid ColumnDefinitions="*,Auto" Padding="0,8">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Retomar de onde parou"
                               FontSize="18"
                               TextColor="{StaticResource TextPrimary}" />
                        <Label Text="Ao ligar o carro, continua a mesma faixa e posição"
                               Style="{StaticResource VwCaption}" />
                    </VerticalStackLayout>
                    <Switch Grid.Column="1"
                            IsToggled="{Binding ResumePlaybackOnStart}"
                            OnColor="{StaticResource Accent}" />
                </Grid>

                <BoxView HeightRequest="1" Color="{StaticResource SurfaceLight}" />

                <Button Text="Limpar sessão salva"
                        Command="{Binding ClearSavedSessionCommand}"
                        Style="{StaticResource VwControlButton}" />

            <Label Text="{Binding AppVersion, StringFormat='ValPlay v{0}'}"
                   Style="{StaticResource VwCaption}"
                   HorizontalOptions="Center"
                   Margin="0,16,0,0" />
            </VerticalStackLayout>
        </ScrollView>
    </controls:VwSafeAreaLayout>
</ContentPage>
