<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ValPlay.ViewModels"
             xmlns:models="clr-namespace:ValPlay.Models"
             xmlns:controls="clr-namespace:ValPlay.Controls"
             x:Class="ValPlay.Pages.LibraryPage"
             x:DataType="vm:LibraryViewModel"
             Title="Biblioteca"
             BackgroundColor="{StaticResource Background}">

    <controls:VwSafeAreaLayout>
        <Grid RowDefinitions="Auto,Auto,Auto,*" Padding="12" RowSpacing="10">

            <SearchBar Placeholder="Buscar música ou vídeo..."
                       Text="{Binding SearchText}"
                       Style="{StaticResource VwSearchBar}" />

            <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Picker Title="Pasta para buscar"
                        ItemsSource="{Binding ScanRoots}"
                        SelectedItem="{Binding SelectedScanRoot}"
                        Style="{StaticResource VwPicker}" />
                <Button Grid.Column="1"
                        Text="Atualizar"
                        Command="{Binding ScanCommand}"
                        IsEnabled="{Binding IsScanning, Converter={StaticResource InvertedBoolConverter}}"
                        Style="{StaticResource VwPrimaryButton}"
                        WidthRequest="140" />
            </Grid>

            <ActivityIndicator Grid.Row="2"
                               IsRunning="{Binding IsScanning}"
                               IsVisible="{Binding IsScanning}"
                               Color="{StaticResource Accent}" />

            <Label Grid.Row="2"
                   Text="{Binding StatusMessage}"
                   Style="{StaticResource VwCaption}"
                   IsVisible="{Binding IsScanning, Converter={StaticResource InvertedBoolConverter}}" />

            <CollectionView Grid.Row="3"
                            ItemsSource="{Binding Items}"
                            SelectedItem="{Binding SelectedItem}"
                            SelectionMode="Single"
                            SelectionChanged="OnSelectionChanged">
                <CollectionView.EmptyView>
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="8">
                        <Label Text="📂" FontSize="48" HorizontalOptions="Center" />
                        <Label Text="Conecte um pendrive ou cartão SD e toque em Atualizar"
                               Style="{StaticResource VwSubtitle}"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:MediaItem">
                        <Grid Padding="10,8"
                              ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="10"
                              BackgroundColor="{StaticResource Surface}">
                            <Label Text="{Binding Type, Converter={StaticResource MediaIconConverter}}"
                                   FontSize="22"
                                   VerticalOptions="Center" />
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                <Label Text="{Binding DisplayTitle}"
                                       FontSize="18"
                                       TextColor="{StaticResource TextPrimary}"
                                       LineBreakMode="TailTruncation" />
                                <Label Text="{Binding DisplaySubtitle}"
                                       Style="{StaticResource VwCaption}" />
                            </VerticalStackLayout>
                            <Button Grid.Column="2"
                                    Text="▶"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:LibraryViewModel}}, Path=PlayItemCommand}"
                                    CommandParameter="{Binding .}"
                                    Style="{StaticResource VwPlayButton}"
                                    WidthRequest="56"
                                    HeightRequest="56"
                                    CornerRadius="28"
                                    FontSize="20"
                                    VerticalOptions="Center" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </controls:VwSafeAreaLayout>
</ContentPage>
