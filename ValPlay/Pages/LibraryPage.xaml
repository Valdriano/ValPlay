<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ValPlay.ViewModels"
             xmlns:models="clr-namespace:ValPlay.Models"
             xmlns:controls="clr-namespace:ValPlay.Controls"
             xmlns:conv="clr-namespace:ValPlay.Converters"
             x:Class="ValPlay.Pages.LibraryPage"
             x:DataType="vm:LibraryViewModel"
             Title="{Binding PageTitle}"
             BackgroundColor="{StaticResource AppBackground}">

    <ContentPage.Resources>
        <conv:LibraryKindToIconConverter x:Key="FolderIconConverter" />
        <conv:LibraryKindToIsFolderConverter x:Key="IsFolderConverter" />
        <conv:LibraryKindToIsMediaConverter x:Key="IsMediaConverter" />
    </ContentPage.Resources>

    <controls:VwSafeAreaLayout>
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*" Padding="12" RowSpacing="10">

            <Grid Grid.Row="0"
                  ColumnDefinitions="*,*,*"
                  ColumnSpacing="8"
                  IsVisible="{Binding IsSearchMode, Converter={StaticResource InvertedBoolConverter}}">
                <Button Text="{Binding PlayAllAudioLabel}"
                        Command="{Binding PlayAllAudioCommand}"
                        Style="{StaticResource VwQuickPlayButton}" />
                <Button Grid.Column="1"
                        Text="{Binding PlayAllVideoLabel}"
                        Command="{Binding PlayAllVideoCommand}"
                        Style="{StaticResource VwQuickPlayButton}" />
                <Button Grid.Column="2"
                        Text="{Binding PlayAllMediaLabel}"
                        Command="{Binding PlayAllMediaCommand}"
                        Style="{StaticResource VwQuickPlayButton}" />
            </Grid>

            <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <SearchBar Placeholder="{Binding SearchPlaceholder}"
                           Text="{Binding SearchText}"
                           Style="{StaticResource VwSearchBar}" />
                <Button Grid.Column="1"
                        Text="{Binding SelectModeLabel}"
                        Command="{Binding ToggleSelectionModeCommand}"
                        Style="{StaticResource VwIconActionButton}"
                        FontSize="13"
                        Padding="10,6"
                        IsEnabled="{Binding HasRows}"
                        IsVisible="{Binding IsSearchMode}" />
            </Grid>

            <Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Picker Title="{Binding ScanFolderTitle}"
                        ItemsSource="{Binding ScanRoots}"
                        SelectedItem="{Binding SelectedScanRoot}"
                        Style="{StaticResource VwPicker}" />
                <Button Grid.Column="1"
                        Text="{Binding RefreshLabel}"
                        Command="{Binding ScanCommand}"
                        IsEnabled="{Binding IsScanning, Converter={StaticResource InvertedBoolConverter}}"
                        Style="{StaticResource VwPrimaryButton}"
                        WidthRequest="150" />
            </Grid>

            <Grid Grid.Row="3"
                  ColumnDefinitions="Auto,*,Auto"
                  ColumnSpacing="8"
                  IsVisible="{Binding IsSearchMode, Converter={StaticResource InvertedBoolConverter}}">
                <Button Text="{Binding BackLabel}"
                        Command="{Binding GoBackCommand}"
                        IsEnabled="{Binding CanGoBack}"
                        Style="{StaticResource VwIconActionButton}"
                        WidthRequest="56"
                        FontSize="18" />
                <Label Grid.Column="1"
                       Text="{Binding CurrentFolderLabel}"
                       Style="{StaticResource VwTitle}"
                       FontSize="18"
                       VerticalOptions="Center"
                       LineBreakMode="TailTruncation" />
                <Button Grid.Column="2"
                        Text="{Binding SelectModeLabel}"
                        Command="{Binding ToggleSelectionModeCommand}"
                        Style="{StaticResource VwIconActionButton}"
                        FontSize="13"
                        Padding="10,6"
                        IsEnabled="{Binding HasRows}"
                        IsVisible="{Binding IsSearchMode, Converter={StaticResource InvertedBoolConverter}}" />
            </Grid>

            <Grid Grid.Row="4"
                  ColumnDefinitions="*,Auto,Auto"
                  ColumnSpacing="8"
                  IsVisible="{Binding IsSelectionMode}">
                <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                    <Button Text="{Binding PlaySelectedLabel}"
                            Command="{Binding PlaySelectedCommand}"
                            Style="{StaticResource VwPrimaryButton}"
                            HorizontalOptions="Start"
                            HeightRequest="48" />
                    <Label Text="{Binding SelectionStatus}"
                           Style="{StaticResource VwCaption}"
                           IsVisible="{Binding SelectedCount}" />
                </VerticalStackLayout>
                <Button Grid.Column="1"
                        Text="{Binding SelectAllLabel}"
                        Command="{Binding SelectAllCommand}"
                        Style="{StaticResource VwIconActionButton}"
                        FontSize="13"
                        VerticalOptions="Center" />
                <Button Grid.Column="2"
                        Text="{Binding ClearSelectionLabel}"
                        Command="{Binding ClearSelectionCommand}"
                        Style="{StaticResource VwIconActionButton}"
                        FontSize="13"
                        VerticalOptions="Center" />
            </Grid>

            <ActivityIndicator Grid.Row="5"
                               IsRunning="{Binding IsScanning}"
                               IsVisible="{Binding IsScanning}"
                               Color="{StaticResource Accent}" />

            <Label Grid.Row="5"
                   Text="{Binding StatusMessage}"
                   Style="{StaticResource VwCaption}"
                   IsVisible="{Binding IsScanning, Converter={StaticResource InvertedBoolConverter}}" />

            <CollectionView Grid.Row="6"
                            ItemsSource="{Binding Rows}"
                            SelectionMode="None">
                <CollectionView.EmptyView>
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="8">
                        <Label Text="📂" FontSize="48" HorizontalOptions="Center" />
                        <Label Text="{Binding EmptyHint}"
                               Style="{StaticResource VwSubtitle}"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:LibraryRow">
                        <Grid Padding="10,8"
                              ColumnDefinitions="Auto,Auto,*,Auto,Auto"
                              ColumnSpacing="8"
                              BackgroundColor="{Binding IsSelected, Converter={StaticResource SelectionBackgroundConverter}}">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:LibraryViewModel}}, Path=OpenOrPlayCommand}"
                                    CommandParameter="{Binding .}" />
                            </Grid.GestureRecognizers>

                            <Label Grid.Column="0"
                                   Text="{Binding IsSelected, Converter={StaticResource SelectionIconConverter}}"
                                   FontSize="24"
                                   TextColor="{StaticResource Accent}"
                                   VerticalOptions="Center"
                                   IsVisible="{Binding Source={RelativeSource AncestorType={x:Type vm:LibraryViewModel}}, Path=IsSelectionMode}">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:LibraryViewModel}}, Path=ToggleRowSelectionCommand}"
                                        CommandParameter="{Binding .}" />
                                </Label.GestureRecognizers>
                            </Label>

                            <Label Grid.Column="1"
                                   Text="{Binding Kind, Converter={StaticResource FolderIconConverter}}"
                                   FontSize="22"
                                   VerticalOptions="Center"
                                   IsVisible="{Binding Kind, Converter={StaticResource IsFolderConverter}}" />
                            <Label Grid.Column="1"
                                   Text="{Binding Media.Type, Converter={StaticResource MediaIconConverter}}"
                                   FontSize="22"
                                   VerticalOptions="Center"
                                   IsVisible="{Binding Kind, Converter={StaticResource IsMediaConverter}}" />

                            <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" Spacing="2">
                                <Label Text="{Binding Title}"
                                       FontSize="18"
                                       TextColor="{StaticResource TextPrimary}"
                                       LineBreakMode="TailTruncation" />
                                <Label Text="{Binding Subtitle}"
                                       Style="{StaticResource VwCaption}" />
                            </VerticalStackLayout>

                            <Button Grid.Column="3"
                                    Text="{Binding Source={RelativeSource AncestorType={x:Type vm:LibraryViewModel}}, Path=PlayFolderIcon}"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:LibraryViewModel}}, Path=PlayFolderCommand}"
                                    CommandParameter="{Binding .}"
                                    IsVisible="{Binding Kind, Converter={StaticResource IsFolderConverter}}"
                                    Style="{StaticResource VwIconActionButton}"
                                    WidthRequest="64"
                                    HeightRequest="56"
                                    FontSize="14"
                                    CornerRadius="28"
                                    VerticalOptions="Center">
                                <Button.Triggers>
                                    <DataTrigger TargetType="Button"
                                                 Binding="{Binding Source={RelativeSource AncestorType={x:Type vm:LibraryViewModel}}, Path=IsSelectionMode}"
                                                 Value="True">
                                        <Setter Property="IsVisible" Value="False" />
                                    </DataTrigger>
                                </Button.Triggers>
                            </Button>

                            <Button Grid.Column="4"
                                    Text="{Binding Source={RelativeSource AncestorType={x:Type vm:LibraryViewModel}}, Path=PlayItemIcon}"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:LibraryViewModel}}, Path=PlayItemCommand}"
                                    CommandParameter="{Binding .}"
                                    IsVisible="{Binding Kind, Converter={StaticResource IsMediaConverter}}"
                                    Style="{StaticResource VwPlayButton}"
                                    WidthRequest="56"
                                    HeightRequest="56"
                                    CornerRadius="28"
                                    FontSize="18"
                                    VerticalOptions="Center">
                                <Button.Triggers>
                                    <DataTrigger TargetType="Button"
                                                 Binding="{Binding Source={RelativeSource AncestorType={x:Type vm:LibraryViewModel}}, Path=IsSelectionMode}"
                                                 Value="True">
                                        <Setter Property="IsVisible" Value="False" />
                                    </DataTrigger>
                                </Button.Triggers>
                            </Button>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </controls:VwSafeAreaLayout>
</ContentPage>
