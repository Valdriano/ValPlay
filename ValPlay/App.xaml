<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:conv="clr-namespace:ValPlay.Converters"
             x:Class="ValPlay.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <conv:InvertedBoolConverter x:Key="InvertedBoolConverter" />
            <conv:TimeSpanToStringConverter x:Key="TimeSpanConverter" />
            <conv:BoolToPlayPauseConverter x:Key="PlayPauseConverter" />
            <conv:RepeatModeToStringConverter x:Key="RepeatConverter" />
            <conv:ShuffleToColorConverter x:Key="ShuffleColorConverter" />
            <conv:MediaTypeToIconConverter x:Key="MediaIconConverter" />
            <conv:BoolToFullscreenIconConverter x:Key="FullscreenIconConverter" />
            <conv:SelectionBackgroundConverter x:Key="SelectionBackgroundConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
